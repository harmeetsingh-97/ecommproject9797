@page
@model LoginWith2faModel
@{
    ViewData["Title"] = "Two-step verification";
}

<div class="min-h-screen flex items-center justify-center bg-gradient-to-br from-[#A8BFA1] to-[#E9DCC9]">
    <div class="bg-white rounded-xl shadow-xl p-8 w-full max-w-md">
        <!-- Heading -->
        <h1 class="font-playfair text-2xl text-gray-900 mb-2">Two-step verification</h1>
        <hr class="border-gray-200 mb-4" />
        <p class="font-dm text-gray-600 mb-6">Enter the OTP sent to your email or phone.</p>

        <!-- Form -->
        <form method="post" asp-route-returnUrl="@Model.ReturnUrl" class="space-y-5">
            <input asp-for="RememberMe" type="hidden" />
            <div asp-validation-summary="ModelOnly" class="text-red-500 text-sm" role="alert"></div>

            <!-- OTP Input -->
            <div>
                <label asp-for="Input.TwoFactorCode" class="block text-xs tracking-widest uppercase font-dm text-gray-700 mb-2">OTP Code</label>
                <input asp-for="Input.TwoFactorCode" autocomplete="off"
                       class="w-full rounded-md bg-gray-100 px-4 py-3 font-dm text-gray-900 focus:outline-none focus:ring-2 focus:ring-black" />
                <span asp-validation-for="Input.TwoFactorCode" class="text-red-500 text-sm"></span>
            </div>

            <!-- Remember Machine -->
            <div class="flex items-center space-x-2">
                <input asp-for="Input.RememberMachine" class="rounded border-gray-300" />
                <label asp-for="Input.RememberMachine" class="font-dm text-sm text-gray-700">@Html.DisplayNameFor(m => m.Input.RememberMachine)</label>
            </div>

            <!-- Submit -->
            <button type="submit"
                    class="w-full bg-black text-white rounded-full py-3 font-dm tracking-wide flex items-center justify-center">
                Log in →
            </button>
        </form>

        <!-- Footer links -->
        <div class="mt-6 space-y-2 text-center">
            <p class="text-sm text-gray-500 font-dm">
                Don't have access to your authenticator device?
                <a id="recovery-code-login" asp-page="./LoginWithRecoveryCode" asp-route-returnUrl="@Model.ReturnUrl"
                   class="underline hover:text-gray-700">Log in with a recovery code</a>.
            </p>
            <form method="post" asp-page-handler="SendSms" asp-route-returnUrl="@Model.ReturnUrl">
                <button type="submit" class="text-sm text-gray-500 underline hover:text-gray-700 font-dm p-0">
                    Send a code to my phone instead
                </button>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
