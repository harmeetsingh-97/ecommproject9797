@model int

<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@600&family=DM+Sans:wght@400;500&display=swap" rel="stylesheet" />



<div class="confirm-page">
    <div class="confirm-card">

        <div class="check-ring">
            <i class="fas fa-check" aria-hidden="true"></i>
        </div>

        <h1 class="confirm-title">Order placed!</h1>
        <p class="confirm-sub">Thank you for your purchase. Your order has been received and is now being processed.</p>

        <div class="order-id-box">
            <span class="order-id-label">Order ID</span>
            <span class="order-id-value">#@Model</span>
        </div>

        <div class="confirm-divider"></div>

        <div class="confirm-note">
            <p><i class="fa fa-envelope" aria-hidden="true"></i>A confirmation email has been sent to your registered address.</p>
            <p><i class="fa fa-truck" aria-hidden="true"></i>Expected delivery within 3 – 5 business days.</p>
        </div>

        <a asp-area="Customer" asp-controller="Home" asp-action="Index" class="btn-shop">
            Continue shopping →
        </a>

    </div>
</div>