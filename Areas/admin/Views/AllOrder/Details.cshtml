@using ecomm_project.models.ViewModels
@model OrderVM



<div class="details-page">
  <h2 class="page-title">Order Details</h2>

  <div class="card-panel">
    <div class="dt-top-bar">
      <div class="dt-show-wrap">
        Show
        <select><option>10</option><option>25</option><option>50</option></select>
        entries
      </div>
      <div class="dt-search-wrap">
        Search: <input type="search" placeholder="" aria-label="Search" />
      </div>
    </div>

    <table id="orderTable" class="orders-tbl">
      <thead>
        <tr>
          <th>Product ID</th>
          <th>Title</th>
          <th>Author</th>
          <th>Quantity</th>
          <th>Price</th>
          <th>Total</th>
        </tr>
      </thead>
      <tbody>
        @foreach (var item in Model.orderDetails)
        {
          <tr>
            <td>@item.productId</td>
            <td>@item.Product.Title</td>
            <td>@item.Product.Author</td>
            <td>@item.Count</td>
            <td>@item.Price.ToString("C")</td>
            <td>@((item.Count * item.Price).ToString("C"))</td>
          </tr>
        }
      </tbody>
      <tfoot>
        <tr>
          <td colspan="5" class="total-label">Grand Total</td>
          <td class="total-value">@Model.orderDetails.Sum(x => x.Count * x.Price).ToString("C")</td>
        </tr>
      </tfoot>
    </table>
  </div>
</div>

@section Scripts {
  <link rel="stylesheet" href="https://cdn.datatables.net/1.13.6/css/jquery.dataTables.min.css" />
  <script src="https://code.jquery.com/jquery-3.7.0.min.js"></script>
  <script src="https://cdn.datatables.net/1.13.6/js/jquery.dataTables.min.js"></script>
  <script>
    $(document).ready(function () { $('#orderTable').DataTable({ searching: false, lengthChange: false, paging: false, info: false }); });
  </script>
  <style>
  .details-page { padding: 2rem; }
  .details-page .page-title { font-family: 'Georgia', 'Times New Roman', serif; font-size: 2.1rem; font-weight: 400; color: #2a2a28; letter-spacing: -0.5px; margin: 0 0 1.75rem; }
  .details-page .card-panel { background: #ffffff; border-radius: 18px; padding: 1.75rem 1.75rem 2rem; box-shadow: 0 4px 24px rgba(0,0,0,0.07); }
  .details-page .dt-top-bar { display: flex; justify-content: space-between; align-items: center; margin-bottom: 1.5rem; flex-wrap: wrap; gap: .75rem; }
  .details-page .dt-show-wrap { display: flex; align-items: center; gap: 8px; font-size: .9rem; color: #666; }
  .details-page .dt-show-wrap select { border: 1.5px solid #e0e0e0; border-radius: 8px; padding: 5px 10px; font-size: .9rem; color: #333; background: #fff; }
  .details-page .dt-search-wrap { display: flex; align-items: center; gap: 8px; font-size: .9rem; color: #666; }
  .details-page .dt-search-wrap input { border: 1.5px solid #e0e0e0; border-radius: 8px; padding: 6px 14px; font-size: .9rem; color: #333; outline: none; width: 220px; }
  .details-page .dt-search-wrap input:focus { border-color: #999; }
  .details-page table.orders-tbl { width: 100%; border-collapse: collapse; }
  .details-page table.orders-tbl thead th { font-size: .72rem; font-weight: 700; letter-spacing: .09em; text-transform: uppercase; color: #aaa; padding: .55rem 1.1rem; border-bottom: 1.5px solid #f0f0f0; text-align: left; }
  .details-page table.orders-tbl tbody tr { border-bottom: 1px solid #f5f5f3; transition: background .15s; }
  .details-page table.orders-tbl tbody tr:last-child { border-bottom: none; }
  .details-page table.orders-tbl tbody tr:hover { background: #fafaf8; }
  .details-page table.orders-tbl tbody td { padding: 1.05rem 1.1rem; font-size: .92rem; color: #2a2a28; vertical-align: middle; }
  .details-page table.orders-tbl tfoot td { padding: 1rem 1.1rem; font-size: .95rem; font-weight: 700; border-top: 2px solid #f0f0f0; color: #2a2a28; }
  .details-page .total-label { text-align: right; color: #666; font-weight: 600; }
  .details-page .total-value { color: #3a8c3f; }
  </style>
}
