@{
    ViewData["Title"] = "User List";
}

<style>
    @@import url('https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400;600&family=DM+Sans:wght@300;400;500&display=swap');

    html, body {
        min-height: 100%;
        margin: 0;
        padding: 0;
    }

    body {
        font-family: 'DM Sans', sans-serif;
        background: linear-gradient(135deg, #c8d8c0 0%, #d4c8a0 50%, #c8b890 100%) !important;
        background-attachment: fixed !important;
    }

    .user-page {
        padding: 40px 24px;
        min-height: 100vh;
    }

    .user-container {
        max-width: 1100px;
        margin: 0 auto;
    }

    /* ── Header ── */
    .user-header {
        display: flex;
        align-items: center;
        justify-content: space-between;
        margin-bottom: 28px;
    }

    .user-title {
        font-family: 'Playfair Display', serif;
        font-size: 2rem;
        font-weight: 600;
        color: #1a1a1a;
        letter-spacing: -0.5px;
        margin: 0;
    }

    .btn-add {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        background: #1a1a1a;
        color: #fff !important;
        font-family: 'DM Sans', sans-serif;
        font-size: 0.92rem;
        font-weight: 500;
        padding: 11px 22px;
        border-radius: 50px;
        text-decoration: none !important;
        letter-spacing: 0.01em;
        transition: background 0.2s, transform 0.1s;
        border: none;
        cursor: pointer;
    }

    .btn-add:hover { background: #333; }
    .btn-add:active { transform: scale(0.98); }

    /* ── Card ── */
    .user-card {
        background: #ffffff;
        border-radius: 16px;
        box-shadow: 0 8px 40px rgba(0,0,0,0.10);
        overflow: hidden;
        padding: 16px 20px 20px;
    }

    /* ── DataTables controls ── */
    .dataTables_wrapper .dataTables_length,
    .dataTables_wrapper .dataTables_filter {
        font-family: 'DM Sans', sans-serif;
        font-size: 0.88rem;
        color: #666;
        margin-bottom: 14px;
    }

    .dataTables_wrapper .dataTables_length select,
    .dataTables_wrapper .dataTables_filter input {
        font-family: 'DM Sans', sans-serif;
        font-size: 0.88rem;
        border: 1.5px solid #e0e0da;
        border-radius: 8px;
        padding: 6px 10px;
        outline: none;
        background: #f7f7f5;
        color: #1a1a1a;
        transition: border-color 0.2s;
    }

    .dataTables_wrapper .dataTables_filter input:focus {
        border-color: #888;
        background: #fff;
    }

    /* ── Table ── */
    #tblData.dataTable {
        width: 100% !important;
        border-collapse: collapse !important;
        font-size: 0.93rem;
    }

    #tblData thead tr { border-bottom: 1.5px solid #e8e8e8; }

    #tblData thead th {
        font-size: 0.68rem !important;
        font-weight: 500 !important;
        letter-spacing: 0.10em;
        text-transform: uppercase;
        color: #888 !important;
        padding: 14px 16px !important;
        text-align: left;
        background: transparent !important;
        border: none !important;
        white-space: nowrap;
    }

    #tblData tbody tr { border-bottom: 1px solid #f0f0ec; transition: background 0.15s; }
    #tblData tbody tr:last-child { border-bottom: none; }
    #tblData tbody tr:hover { background: #f9f8f5 !important; }

    #tblData tbody td {
        padding: 13px 16px !important;
        color: #1a1a1a;
        vertical-align: middle;
        border: none !important;
        background: transparent !important;
    }

    table.dataTable.table-striped > tbody > tr.odd > * { box-shadow: none; background: transparent; }
    table.dataTable.table-bordered { border: none !important; }

    /* ── Avatar initials ── */
    .user-avatar {
        width: 36px;
        height: 36px;
        border-radius: 50%;
        background: #e8e4d8;
        color: #6b6455;
        font-size: 0.78rem;
        font-weight: 500;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        letter-spacing: 0.04em;
        flex-shrink: 0;
    }

    .user-name-cell {
        display: flex;
        align-items: center;
        gap: 10px;
    }

    .user-name-text {
        font-weight: 500;
        color: #1a1a1a;
        font-size: 0.93rem;
    }

    /* ── Role badge ── */
    .role-badge {
        display: inline-block;
        font-size: 0.72rem;
        font-weight: 500;
        letter-spacing: 0.06em;
        padding: 4px 11px;
        border-radius: 50px;
        text-transform: capitalize;
    }

    .role-admin   { background: #1a1a1a; color: #fff; }
    .role-company { background: #e8f0e4; color: #3b6211; }
    .role-customer{ background: #eef3fb; color: #185fa5; }
    .role-default { background: #f0f0ec; color: #666; }

    /* ── Action buttons ── */
    .btn-dt-edit {
        display: inline-flex;
        align-items: center;
        gap: 5px;
        font-family: 'DM Sans', sans-serif;
        font-size: 0.80rem;
        font-weight: 500;
        padding: 6px 13px;
        border-radius: 50px;
        border: 1.5px solid #d0d0ca;
        background: transparent;
        color: #444;
        cursor: pointer;
        text-decoration: none;
        transition: border-color 0.15s, background 0.15s, color 0.15s;
    }
    .btn-dt-edit:hover { border-color: #1a1a1a; color: #1a1a1a; background: #f4f4f0; text-decoration: none; }

    .btn-dt-lock {
        display: inline-flex;
        align-items: center;
        gap: 5px;
        font-family: 'DM Sans', sans-serif;
        font-size: 0.80rem;
        font-weight: 500;
        padding: 6px 13px;
        border-radius: 50px;
        border: 1.5px solid #f0c8c5;
        background: transparent;
        color: #c0392b;
        cursor: pointer;
        text-decoration: none;
        transition: border-color 0.15s, background 0.15s;
    }
    .btn-dt-lock:hover { border-color: #c0392b; background: #fff5f5; text-decoration: none; }

    /* ── Pagination ── */
    .dataTables_wrapper .dataTables_paginate {
        font-family: 'DM Sans', sans-serif;
        font-size: 0.88rem;
        margin-top: 16px;
    }

    .dataTables_wrapper .dataTables_paginate .paginate_button {
        border-radius: 8px !important;
        padding: 5px 12px !important;
        margin: 0 2px;
        border: 1.5px solid transparent !important;
        color: #555 !important;
        background: transparent !important;
        box-shadow: none !important;
        transition: background 0.15s, border-color 0.15s;
    }

    .dataTables_wrapper .dataTables_paginate .paginate_button:hover {
        background: #f0f0ec !important;
        border-color: #d0d0ca !important;
        color: #1a1a1a !important;
    }

    .dataTables_wrapper .dataTables_paginate .paginate_button.current,
    .dataTables_wrapper .dataTables_paginate .paginate_button.current:hover {
        background: #1a1a1a !important;
        border-color: #1a1a1a !important;
        color: #fff !important;
        border-radius: 50px !important;
    }

    .dataTables_wrapper .dataTables_paginate .paginate_button.disabled,
    .dataTables_wrapper .dataTables_paginate .paginate_button.disabled:hover {
        color: #bbb !important;
        cursor: default;
    }

    .dataTables_wrapper .dataTables_info {
        font-family: 'DM Sans', sans-serif;
        font-size: 0.85rem;
        color: #888;
        margin-top: 16px;
    }
</style>

<div class="user-page">
    <div class="user-container">

        <div class="user-header">
            <h2 class="user-title">User List</h2>
            <a asp-page="/Account/Register" asp-area="Identity" class="btn-add">
                <i class="fas fa-plus"></i> Add New User
            </a>
        </div>

        <div class="user-card">
            <table id="tblData" class="user-table">
                <thead>
                    <tr>
                        <th>Name</th>
                        <th>Email</th>
                        <th>Phone Number</th>
                        <th>Company</th>
                        <th>Role</th>
                        <th>Actions</th>
                    </tr>
                </thead>
            </table>
        </div>

    </div>
</div>

@section Scripts {
    <script src="~/js/user.js"></script>
}
